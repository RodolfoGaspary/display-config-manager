<Window x:Class="DisplayConfigManager.UI.SavePresetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Preset"
        Width="340" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Enter a name for this display configuration:" TextWrapping="Wrap"/>

        <TextBox x:Name="NameBox" Grid.Row="2"
                 Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="80"
                 KeyDown="NameBox_KeyDown"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="Save" Width="75" Margin="0,0,8,0"
                    IsDefault="True" Click="SaveButton_Click"
                    IsEnabled="{Binding IsNameValid}"/>
            <Button Content="Cancel" Width="75" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
