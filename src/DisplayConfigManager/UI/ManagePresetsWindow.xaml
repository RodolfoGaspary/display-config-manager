<Window x:Class="DisplayConfigManager.UI.ManagePresetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Presets"
        Width="420" Height="360"
        MinWidth="300" MinHeight="200"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="PresetList" Grid.Row="0"
                 ItemsSource="{Binding Presets}"
                 HorizontalContentAlignment="Stretch"
                 SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Rename" MinWidth="60" Margin="0,0,4,0" Padding="6,2"
                                    Tag="{Binding}"
                                    Click="RenameButton_Click"/>
                            <Button Content="Delete" MinWidth="60" Padding="6,2"
                                    Tag="{Binding}"
                                    Click="DeleteButton_Click"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="2" Content="Close" Width="80"
                HorizontalAlignment="Right" IsCancel="True"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
